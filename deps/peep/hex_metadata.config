{<<"links">>,[{<<"GitHub">>,<<"https://github.com/rkallos/peep">>}]}.
{<<"name">>,<<"peep">>}.
{<<"version">>,<<"4.4.0">>}.
{<<"description">>,
 <<"Provides an opinionated Telemetry.Metrics reporter that supports StatsD and Prometheus.">>}.
{<<"elixir">>,<<"~> 1.15">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/peep.ex">>,<<"lib/peep">>,<<"lib/peep/buckets">>,
  <<"lib/peep/buckets/exponential.ex">>,<<"lib/peep/buckets/custom.ex">>,
  <<"lib/peep/buckets/powers_of_ten.ex">>,<<"lib/peep/telemetry.ex">>,
  <<"lib/peep/options.ex">>,<<"lib/peep/event_handler.ex">>,
  <<"lib/peep/statsd">>,<<"lib/peep/statsd/cache.ex">>,
  <<"lib/peep/statsd/packet.ex">>,<<"lib/peep/storage">>,
  <<"lib/peep/storage/atomics.ex">>,<<"lib/peep/storage/striped.ex">>,
  <<"lib/peep/storage/ets.ex">>,<<"lib/peep/buckets.ex">>,
  <<"lib/peep/storage.ex">>,<<"lib/peep/prometheus.ex">>,
  <<"lib/peep/statsd.ex">>,<<"lib/peep/persistent.ex">>,<<"lib/plug.ex">>,
  <<"test/shared">>,<<"test/shared/test_helpers.ex">>,
  <<"test/shared/storage_test.exs">>,<<"LICENSE">>,<<"mix.exs">>,
  <<"README.md">>]}.
{<<"app">>,<<"peep">>}.
{<<"licenses">>,[<<"Apache-2.0">>]}.
