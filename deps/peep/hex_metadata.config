   {<<"app">>,<<"nimble_options">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.1">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"telemetry">>},
   {<<"app">>,<<"telemetry">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.0">>},
   {<<"repository">>,<<"hexpm">>}],
  [{<<"name">>,<<"telemetry_metrics">>},
   {<<"app">>,<<"telemetry_metrics">>},
   {<<"optional">>,false},
   {<<"requirement">>,<<"~> 1.0">>},
